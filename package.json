{
  "name": "liz-tracker",
  "version": "1.2.0",
  "description": "Liz Tracker — lightweight project management tracker with kanban UI, REST API, MCP tools, and AI agent orchestrator",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "./scripts/with-node.sh tsc && ./scripts/with-node.sh node scripts/build-ui.js",
    "build:ui": "./scripts/with-node.sh node scripts/build-ui.js",
    "start": "./scripts/with-node.sh node dist/index.js",
    "dev": "./scripts/with-node.sh node scripts/build-ui.js && ./scripts/with-node.sh tsx src/index.ts",
    "typecheck": "./scripts/with-node.sh tsc --noEmit",
    "test": "./scripts/with-node.sh vitest run",
    "test:watch": "./scripts/with-node.sh vitest",
    "test:coverage": "./scripts/with-node.sh vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.80",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opencode-ai/sdk": "^1.2.27",
    "better-sqlite3": "^11.8.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "GPL-3.0-only",
  "author": "Martin Dougiamas (https://github.com/moodler)",
  "repository": {
    "type": "git",
    "url": "https://github.com/moodler/liz-tracker.git"
  },
  "homepage": "https://github.com/moodler/liz-tracker",
  "bugs": {
    "url": "https://github.com/moodler/liz-tracker/issues"
  }
}
