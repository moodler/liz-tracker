{
  "name": "liz-tracker",
  "version": "1.1.0",
  "description": "Liz Tracker — lightweight project management tracker with kanban UI, REST API, MCP tools, and OpenCode orchestrator",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opencode-ai/sdk": "^1.2.19",
    "better-sqlite3": "^11.8.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "GPL-3.0-only",
  "author": "Martin Dougiamas (https://github.com/moodler)",
  "repository": {
    "type": "git",
    "url": "https://github.com/moodler/liz-tracker.git"
  },
  "homepage": "https://github.com/moodler/liz-tracker",
  "bugs": {
    "url": "https://github.com/moodler/liz-tracker/issues"
  }
}
