# Liz Tracker configuration
# Copy this file to .env and edit as needed.
# Environment variables override these values.

# Server
PORT=1000
STORE_DIR=./store

# Your display name (used as default assignee for owner-review states)
OWNER_NAME=Owner

# Actor classification — comma-separated names
# These names are recognised as human actors (can approve items for execution)
HUMAN_ACTORS=dashboard,me
# These names are recognised as AI agent actors
AGENT_ACTORS=coder

# API authentication (auto-generated on first run if not set)
# TRACKER_API_TOKEN=your-secret-token

# Orchestrator (disabled by default — requires an OpenCode server)
ORCHESTRATOR_ENABLED=false
OPENCODE_SERVER_URL=http://localhost:3000
# OPENCODE_PUBLIC_URL=http://localhost:3000
# ORCHESTRATOR_INTERVAL=30000
# OPENCODE_MAX_CONCURRENT=3
# OPENCODE_MAX_PER_PROJECT=1
# SESSION_TIMEOUT=2700000

# AI model for coder bot sessions
# CODER_MODEL_PROVIDER=anthropic
# CODER_MODEL_ID=claude-opus-4-6

# Circuit breaker — auto-pauses orchestrator after repeated failures
# CIRCUIT_BREAKER_THRESHOLD=2
# CIRCUIT_BREAKER_WINDOW=3600000

# Per-item retry limit — auto-shelves items that fail repeatedly
# ITEM_DISPATCH_FAILURE_LIMIT=3

# Container path translation (for agents running inside containers)
# ASSISTANT_PROJECT_ROOT=~/assistant
